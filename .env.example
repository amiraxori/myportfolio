# ─── Database ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=

# ─── Admin Seed Credentials (used by seed-admin script only) ───────────────────
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_PASSWORD=

# ─── Cloudinary ────────────────────────────────────────────────────────────────
CLOUDINARY_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ─── Resend (email) ────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── Pusher (real-time chat) ───────────────────────────────────────────────────
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=

# These are exposed to the browser — must match PUSHER_KEY / PUSHER_CLUSTER above
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=
